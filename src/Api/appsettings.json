{
  "Serilog": {
  "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.AspNetCore.Mvc.Infrastructure": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Template": {
    "ImagesRequestPath": "/images",
    "MaxImageSizeMb": 25,
    "AllowedImageExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp", ".tif", ".tiff", ".avif", ".svg"]
  }
}